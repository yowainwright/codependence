ARG NODE_ALPINE_IMAGE
FROM ${NODE_ALPINE_IMAGE}

RUN apk add --no-cache bash

WORKDIR /app

ARG CODEPENDENCE_VERSION
RUN npm install -g codependence@${CODEPENDENCE_VERSION}

COPY tests/release/fixtures/smoke-package.json ./package.json
COPY tests/release/fixtures/smoke-codependencerc.json ./.codependencerc

CMD ["/bin/sh"]
