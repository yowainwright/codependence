[package]
name = "codependence-e2e"
version = "0.1.0"
edition = "2021"

[dependencies]
serde = "1.0.190"
tokio = { version = "1.35.0", features = ["full"] }
local-crate = { path = "../local-crate" }

[dev-dependencies]
pretty_assertions = "1.4.0"

[build-dependencies]
cc = "1.0.83"

[target.'cfg(unix)'.dependencies]
libc = "0.2.150"
