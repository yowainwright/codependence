# Multi-language Dockerfile for testing codependence with Python and Go
ARG NODE_SLIM_IMAGE=node:24-slim@sha256:2c87ef9bd3c6a3bd4b472b4bec2ce9d16354b0c574f736c476489d09f560a203
FROM ${NODE_SLIM_IMAGE} AS builder

ARG BUN_VERSION
ARG BUN_LINUX_X64_SHA256=951ee2aee855f08595aeec6225226a298d3fea83a3dcd6465c09cbccdf7e848f
ARG BUN_LINUX_AARCH64_SHA256=a27ffb63a8310375836e0d6f668ae17fa8d8d18b88c37c821c65331973a19a3b
ARG TARGETARCH

# Install build tools
RUN apt-get update && apt-get install -y \
    curl \
    unzip \
    wget \
    git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy package files
COPY package.json ./
COPY bun.lock ./
COPY bunfig.toml ./
COPY page/ ./page/

# Install bun from a pinned release asset
RUN set -eu; \
    detected_arch="${TARGETARCH:-$(dpkg --print-architecture)}"; \
    case "$detected_arch" in \
        amd64) bun_arch="x64" ;; \
        arm64) bun_arch="aarch64" ;; \
        *) echo "Unsupported Bun architecture: $detected_arch" >&2; exit 1 ;; \
    esac; \
    case "$bun_arch" in \
        x64) bun_sha="$BUN_LINUX_X64_SHA256" ;; \
        aarch64) bun_sha="$BUN_LINUX_AARCH64_SHA256" ;; \
    esac; \
    curl -fsSLo /tmp/bun.zip "https://github.com/oven-sh/bun/releases/download/bun-v${BUN_VERSION}/bun-linux-${bun_arch}.zip"; \
    echo "${bun_sha}  /tmp/bun.zip" | sha256sum -c -; \
    unzip -q /tmp/bun.zip -d /tmp; \
    mv "/tmp/bun-linux-${bun_arch}/bun" /usr/local/bin/bun; \
    chmod +x /usr/local/bin/bun; \
    ln -sf /usr/local/bin/bun /usr/local/bin/bunx; \
    rm -rf /tmp/bun.zip "/tmp/bun-linux-${bun_arch}"

# Install Node.js dependencies
RUN bun install --frozen-lockfile --ignore-scripts

# Copy source code and build
COPY . .
RUN bun run build-dist

# Multi-language test stage with Python and Go
FROM ${NODE_SLIM_IMAGE} AS multilang-test

# Install system dependencies for Python, Go, and other tools
RUN apt-get update && apt-get install -y \
    curl \
    wget \
    git \
    python3 \
    && rm -rf /var/lib/apt/lists/*

# Install Go
ARG GO_VERSION=1.21.5
ARG TARGETARCH
RUN set -eu; \
    go_arch="${TARGETARCH:-$(dpkg --print-architecture)}"; \
    case "$go_arch" in \
        amd64|arm64) ;; \
        *) echo "Unsupported Go architecture: $go_arch" >&2; exit 1 ;; \
    esac; \
    wget -q "https://go.dev/dl/go${GO_VERSION}.linux-${go_arch}.tar.gz"; \
    tar -C /usr/local -xzf "go${GO_VERSION}.linux-${go_arch}.tar.gz"; \
    rm "go${GO_VERSION}.linux-${go_arch}.tar.gz"

ENV PATH="/usr/local/go/bin:$PATH"
ENV GOPATH="/go"
ENV PATH="$GOPATH/bin:$PATH"

COPY --from=builder /usr/local/bin/bun /usr/local/bin/bun
COPY --from=builder /usr/local/bin/bunx /usr/local/bin/bunx

# Create test user
RUN groupadd -g 1001 testuser && \
    useradd -r -u 1001 -g testuser -m testuser && \
    mkdir -p /go && \
    chown -R testuser:testuser /go

WORKDIR /test

# Copy built distribution from builder
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/package.json ./package.json
COPY --from=builder /app/bun.lock ./bun.lock
COPY --from=builder /app/bunfig.toml ./bunfig.toml
COPY --from=builder /app/page ./page

# Install production dependencies
RUN bun install --production --frozen-lockfile --ignore-scripts

# Copy all test fixtures
COPY tests/e2e/fixtures/ ./

# Copy e2e test scripts
COPY tests/e2e/test-go-update.sh ./

# Make all test scripts executable
RUN chmod +x *.sh

# Change ownership
RUN chown -R testuser:testuser /test

# Switch to test user
USER testuser

# Set default command to run Python/Go tests
CMD ["./test-python-go.sh"]
