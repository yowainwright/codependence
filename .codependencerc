{
  "targets": [
    {
      "manager": "bun",
      "files": ["package.json"],
      "codependencies": [
        {
          "@perryts/perry": "0.5.1220"
        },
        "bun-types",
        "fast-check",
        "oxfmt",
        "oxlint",
        "pastoralist",
        "prettier",
        "release-it",
        "turbo",
        {
          "typescript": "^5.9.3"
        }
      ]
    },
    {
      "manager": "github-actions",
      "files": [
        "action.yml",
        ".github/actions/*/action.yml",
        ".github/actions/*/action.yaml",
        ".github/workflows/*.yml",
        ".github/workflows/*.yaml"
      ],
      "mode": "precise"
    }
  ]
}
