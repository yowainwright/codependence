# Local development secrets can be resolved with 1Password:
# op run --env-file=.env -- bun test
# Keep the Socket token hash in 1Password too, but it is token-management
# metadata and does not need to be exported for local scans.
TURBO_TOKEN=
TURBO_TEAM=
SOCKET_SECURITY_API_KEY=
SOCKET_SECURITY_API_KEY_HASH=




