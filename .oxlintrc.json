{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "jsPlugins": [
    {
      "name": "legibility",
      "specifier": "eslint-plugin-legibility"
    }
  ],
  "rules": {
    "legibility/hoist-if-operators": "warn",
    "legibility/max-array-chain-depth": "warn",
    "legibility/max-control-flow-depth": "warn",
    "legibility/max-expression-operators": "warn",
    "legibility/no-complex-ternaries": "warn",
    "legibility/no-computed-values": "warn",
    "legibility/no-direct-node-bin-smoke": "warn",
    "legibility/no-hidden-side-effects": "warn",
    "legibility/no-identity-array-callback": "warn",
    "legibility/no-mixed-filename-casing": "warn",
    "legibility/no-quadratic-patterns": "warn",
    "legibility/no-redundant-boolean-logic": "warn",
    "legibility/no-redundant-nullish-fallback": "warn",
    "legibility/no-standalone-array-mutations": "warn",
    "legibility/no-trivial-wrapper-functions": "warn",
    "legibility/no-unnecessary-block-callback": "warn",
    "legibility/prefer-concat-object-assign": "warn",
    "legibility/prefer-early-return": "warn",
    "legibility/prefer-flat-map": "warn",
    "legibility/prefer-guard-clauses": "warn",
    "legibility/prefer-object-lookup": "warn",
    "legibility/require-executable-shebang": "warn",
    "legibility/require-filename-matches-dirname": "warn"
  }
}
