{
  "name": "codependence",
  "version": "1.0.0",
  "description": "Enforce dependency version policy across projects, workspaces, and CI.",
  "homepage": "https://jeffry.in/codependence",
  "bugs": {
    "url": "https://github.com/yowainwright/codependence/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yowainwright/codependence.git"
  },
  "author": "Jeff Wainwright <yowainwright@gmail.com> (https://jeffry.in)",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "devDependencies": {
    "@perryts/perry": "^0.5.1220",
    "bun-types": "1.3.14",
    "eslint-plugin-legibility": "^0.1.12",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "pastoralist": "^1.12.8",
    "prettier": "^3.9.4",
    "release-it": "20.2.1",
    "turbo": "^2.10.3",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "undici": "7.28.0",
    "vite": "8.1.3"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "codependence": "dist/cli.js",
    "cdp": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "scripts/install-legibility-skill.js"
  ],
  "keywords": [
    "peerDependencies",
    "optionalDependencies",
    "optional-dependencies",
    "dependencies",
    "devDependencies",
    "dependency-policy",
    "version-policy",
    "versioning",
    "versions",
    "monorepo",
    "ci",
    "semver"
  ],
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run build-dist",
    "build:bin": "bun scripts/build-bin.ts",
    "build-dist": "bun build src/index.ts --format esm --outfile dist/index.js --target node && bun build src/index.ts --format cjs --outfile dist/index.cjs --target node && bun build src/cli.ts --format esm --outfile dist/cli.js --target node && chmod +x dist/cli.js && bunx tsc --emitDeclarationOnly --declaration --outDir dist --rootDir src",
    "clean-dist": "rm -rf dist",
    "clean": "bun run clean-dist && cd page/app && rm -rf dist",
    "cmd:node:test-fail-run": "node dist/cli.js --config './tests/unit/fixtures/test-fail-package.json' --files 'test-fail-package.json' --rootDir './tests/unit/fixtures/' --debug",
    "cmd:node:test-pass-run": "node dist/cli.js --config './tests/unit/fixtures/test-pass-package.json' --files 'test-pass-package.json'  --rootDir './tests/unit/fixtures/' --debug",
    "cmd:bun:test-search": "bun src/cli.ts --rootDir './tests/unit/fixtures/' --debug --searchPath './tests/unit/fixtures/.codependencerc' --isTestingCLI",
    "cmd:bun:test-fail-run": "bun src/cli.ts --config './tests/unit/fixtures/test-fail-package.json' --files 'test-fail-package.json' --rootDir './tests/unit/fixtures/' --debug",
    "cmd:bun:test-pass-run": "bun src/cli.ts --config './tests/unit/fixtures/test-pass-package.json' --files 'test-pass-package.json'  --rootDir './tests/unit/fixtures/' --debug",
    "cmd:bun:test-update-run": "bun src/cli.ts --config './tests/unit/fixtures/test-fail-package.json' --files 'test-fail-package.json' --rootDir './tests/unit/fixtures/' --debug --isTesting",
    "cmd:bun:test-codependencies-cli": "bun src/cli.ts -c './tests/unit/fixtures/test-fail-package.json' --files 'test-fail-package.json' -cds 'lodash' '{ \"fs-extra\": \"10.0.1\" }' --rootDir './tests/unit/fixtures/' --debug --isTesting",
    "coverage": "bun test --coverage",
    "dev": "turbo run dev",
    "docs:dev": "turbo run dev --filter=@codependence/docs",
    "docs:build": "turbo run build --filter=@codependence/docs",
    "docs:preview": "turbo run preview --filter=@codependence/docs",
    "deps:overrides": "pastoralist --remove-unused --summary",
    "deps:security": "pastoralist --checkSecurity --securityProvider osv --hasWorkspaceSecurityChecks --summary --strict && bun audit",
    "format-src": "oxfmt --write src",
    "format-test": "oxfmt --write tests",
    "format-app": "prettier --write page/app",
    "format": "bun run format-src && bun run format-test && bun run format-app",
    "lint": "bun run lint-src",
    "lint-fix": "oxlint . --fix",
    "lint-src": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "hooks:setup": "sh scripts/setup-hooks.sh",
    "prepare": "bun run hooks:setup",
    "prepublishOnly": "bun run clean-dist && bun run build-dist",
    "preview": "turbo run preview",
    "release": "bun scripts/release.ts",
    "release:alpha": "bun scripts/release.ts --preRelease=alpha",
    "release:alpha:dry": "bun scripts/release.ts --preRelease=alpha --dry-run",
    "release:beta": "bun scripts/release.ts --preRelease=beta",
    "release:beta:dry": "bun scripts/release.ts --preRelease=beta --dry-run",
    "release:rc": "bun scripts/release.ts --preRelease=rc",
    "release:rc:dry": "bun scripts/release.ts --preRelease=rc --dry-run",
    "release:tag": "bun scripts/tag-release.ts",
    "release:tag:dry": "bun scripts/tag-release.ts --dry-run",
    "release:dry": "bun scripts/release.ts --dry-run",
    "setup": "bun install && bun run hooks:setup && bun run build",
    "test": "bun run test-src",
    "test:e2e:binary": "./tests/e2e/test-binary.sh",
    "test-src": "bun test",
    "typecheck": "bun run typecheck-src",
    "typecheck-src": "tsc --noEmit",
    "update": "bun update",
    "validate": "bun run typecheck && bun run lint && bun run test",
    "validate:full": "bun run validate && ./tests/e2e/test-multilang.sh all",
    "skills:install": "node scripts/install-legibility-skill.js agents",
    "skills:install:claude": "node scripts/install-legibility-skill.js claude",
    "skills:install:claude:local": "node scripts/install-legibility-skill.js claude --local",
    "skills:install:codex": "node scripts/install-legibility-skill.js codex",
    "skills:install:codex:local": "node scripts/install-legibility-skill.js codex --local",
    "skills:install:local": "node scripts/install-legibility-skill.js agents --local"
  },
  "type": "module",
  "types": "dist/index.d.ts",
  "workspaces": [
    "page/app"
  ],
  "pastoralist": {
    "appendix": {
      "undici@7.28.0": {
        "dependents": {
          "codependence": "undici (required by release-it)"
        },
        "ledger": {
          "addedDate": "2026-06-28T00:00:00.000Z"
        }
      },
      "vite@8.1.3": {
        "dependents": {
          "codependence": "vite (unused override)",
          "@codependence/docs": "vite@^8.1.0"
        },
        "ledger": {
          "addedDate": "2026-07-02T00:00:00.000Z"
        }
      }
    },
    "depPaths": "workspace",
    "security": {
      "provider": "osv",
      "severityThreshold": "medium",
      "hasWorkspaceSecurityChecks": true
    }
  },
  "dependencies": {},
  "peerDependencies": {},
  "optionalDependencies": {}
}
