---
import { resolveDocsUrl } from "../../utils/urlResolver";
import IntegrationTerminal from "./IntegrationTerminal";
---

<div class="flex justify-center py-20 lg:py-28">
  <div class="xl:flex gap-16 max-w-6xl">
    <IntegrationTerminal client:visible />

    <div class="xl:max-w-lg flex flex-col justify-center font-sans">
      <h1 class="text-4xl lg:text-5xl font-black">
        Fits Your <span class="text-primary">Workflow</span>
      </h1>

      <p class="mt-8 text-lg">
        Codependence runs where you need policy enforcement: local terminals, package scripts, GitHub Actions, or other CI systems.
      </p>

      <p class="mt-4 text-lg">
        Use it to check drift, preview changes, update manifests, and produce structured output for automation.
      </p>

      <div class="flex gap-4 mt-8">
        <a href={resolveDocsUrl("introduction")} class="btn rounded-lg border-none bg-primary text-primary-content hover:bg-primary/80">Get Started</a>
        <a href={resolveDocsUrl("policy-surface")} class="btn btn-outline rounded-lg border-none">View Policy Surface</a>
      </div>
    </div>
  </div>
</div>
